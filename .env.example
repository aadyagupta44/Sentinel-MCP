# ═══════════════════════════════════════════════════════════════════════════════
# Sentinel MCP — Environment Variable Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
# Transport: stdio (Claude Desktop) or http (remote/OAuth)
MCP_TRANSPORT=stdio
HTTP_HOST=0.0.0.0
HTTP_PORT=8000
LOG_LEVEL=INFO
# development | production | test
ENVIRONMENT=development

# ── Analyst Identity (stdio transport only) ───────────────────────────────────
# Used as analyst_id in every audit log entry when running via stdio.
# On HTTP transport, identity comes from the OAuth JWT token.
ANALYST_ID=analyst@acmecorp.com
# analyst | senior_analyst | admin
ANALYST_ROLE=analyst

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Redis (rate limiting) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OPA Policy Engine ─────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181
# Set false to bypass policy checks (development only — never in production)
POLICY_ENFORCEMENT=true

# ── Auth / Keycloak (HTTP transport only) ─────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=sentinel
OAUTH_CLIENT_ID=claude-desktop

# ── OpenSearch (SIEM) ─────────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_VERIFY_SSL=false
OPENSEARCH_INDEX_ALERTS=sentinel-alerts
OPENSEARCH_INDEX_LOGS=sentinel-logs-*

# ── Wazuh (EDR) ───────────────────────────────────────────────────────────────
# Disabled by default. Run full Wazuh stack only if you have 8GB+ RAM available.
WAZUH_ENABLED=false
WAZUH_URL=https://localhost:55000
WAZUH_API_KEY=
WAZUH_VERIFY_SSL=false

# ── Threat Intelligence — ALL OPTIONAL ────────────────────────────────────────
# The server works without these. Each enables richer enrichment.
# Free sign-up (no credit card required):

# VirusTotal — https://www.virustotal.com/gui/join-us (free: 500/day, 4/min)
VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/register (free: 1,000/day)
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com (free: 10,000/day)
ALIENVAULT_OTX_API_KEY=

# URLScan.io — https://urlscan.io/user/signup (free: 10,000 searches/day)
URLSCAN_API_KEY=

# ── Anthropic (optional narrative generation) ─────────────────────────────────
# If disabled, generate_incident_report returns structured data only.
# Claude synthesises the narrative naturally — this is the recommended default.
REPORT_NARRATIVE_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenCTI (optional, self-hosted) ──────────────────────────────────────────
OPENCTI_ENABLED=false
OPENCTI_URL=http://localhost:8082
OPENCTI_TOKEN=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=sentinel-mcp
OTEL_ENABLED=true

# ── Mock Mode ─────────────────────────────────────────────────────────────────
# true  → all adapters return realistic fake data when the real service is absent
# false → adapters fail if the service is unreachable
MOCK_ADAPTERS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ── Write Tool Confirmation ───────────────────────────────────────────────────
# Time window (seconds) for confirming a proposed write action
PENDING_ACTION_TTL_SECONDS=600

# ── MITRE ATT&CK ──────────────────────────────────────────────────────────────
MITRE_ATTACK_URL=https://github.com/mitre-attack/attack-stix-data/raw/master/enterprise-attack/enterprise-attack.json
MITRE_REFRESH_INTERVAL_HOURS=168

# ── abuse.ch Feeds ────────────────────────────────────────────────────────────
ABUSE_CH_REFRESH_INTERVAL_MINUTES=60
