# ─────────────────────────────────────────────────────────────────────────────
# Production DEMO environment (Setup 2).
# Copy to .env.prod and fill in, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
#
# Only three values are required. Everything else is set in the compose file.
# ─────────────────────────────────────────────────────────────────────────────

# Your public domain WITHOUT scheme. The app is served at https://<DOMAIN> and
# Keycloak at https://id.<DOMAIN>. With DuckDNS, id.<name>.duckdns.org resolves
# automatically (wildcard), so just use your base name here.
#   e.g. DOMAIN=sentinel-soc.duckdns.org
DOMAIN=sentinel-soc.duckdns.org

# Strong password for the Postgres user (used by both the app and Keycloak).
# Generate one:  openssl rand -base64 24
POSTGRES_PASSWORD=change-me-postgres

# Keycloak admin console password (user: admin, at https://id.<DOMAIN>).
# Generate one:  openssl rand -base64 24
KC_ADMIN_PASSWORD=change-me-keycloak-admin
