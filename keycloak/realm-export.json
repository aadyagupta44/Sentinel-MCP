{
  "realm": "sentinel",
  "enabled": true,
  "displayName": "Sentinel SOC",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "clients": [
    {
      "clientId": "claude-desktop",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "redirectUris": [
        "http://localhost:*",
        "https://claude.ai/*",
        "https://*.hf.space/*"
      ],
      "webOrigins": ["+"]
    }
  ],
  "roles": {
    "realm": [
      { "name": "analyst", "description": "Standard SOC analyst — read-only tools" },
      { "name": "senior_analyst", "description": "Senior analyst — includes write/action tools" },
      { "name": "admin", "description": "SOC administrator — unrestricted access" }
    ]
  },
  "users": [
    {
      "username": "analyst",
      "email": "analyst@acmecorp.com",
